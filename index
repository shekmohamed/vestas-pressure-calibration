  </button>
  <div class="toolbar-actions" id="toolbar-actions">
    <span id="saved-label"></span>
    <span id="status">Loading document…</span>
    <button class="btn btn-save"         onclick="saveRecord(); closeMenu()">💾 Save</button>
    <button class="btn btn-update"       onclick="updateRecord(); closeMenu()">🔄 Update</button>
    <button class="btn btn-download-pdf" onclick="downloadPDF(); closeMenu()">⬇ PDF</button>
    <button class="btn btn-print"        onclick="window.print(); closeMenu()">🖨 Print</button>
    <button class="btn btn-clear"        onclick="resetForm(); closeMenu()">✖ Reset</button>
    <button class="btn btn-history"      onclick="openModal('history'); closeMenu()">📜 History</button>
    <button class="btn btn-records"      onclick="openModal('records'); closeMenu()">📂 Records</button>
    <button class="btn btn-records"      style="background:#6f42c1;" onclick="toggleSearch(); closeMenu()">🔍 Search</button>
  </div>
</div>

<!-- Search Bar (toggled) -->
<div id="search-bar" style="position:fixed;top:50px;left:0;right:0;z-index:999;">
  <input id="search-input" type="text" placeholder="Search by DC No…" oninput="doSearch(this.value)" />
