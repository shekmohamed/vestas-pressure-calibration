// ══════════════════════════════════════════════════════
// RENDER PDF + OVERLAY FIELDS
// ══════════════════════════════════════════════════════
pdfjsLib.GlobalWorkerOptions.workerSrc =
  'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

async function init() {
  const status = document.getElementById('status');
  const wrap   = document.getElementById('viewer-wrap');

  try {
    const raw  = atob(PDF_BASE64);
    const buf  = new Uint8Array(raw.length);
    for (let i = 0; i < raw.length; i++) buf[i] = raw.charCodeAt(i);

    const pdf  = await pdfjsLib.getDocument({ data: buf }).promise;
    status.textContent = `${pdf.numPages} page(s) — fill in the yellow fields, then Print`;

    for (let p = 1; p <= pdf.numPages; p++) {
      const page     = await pdf.getPage(p);
      const viewport = page.getViewport({ scale: 1.65 }); // ≈ A4 at 96dpi

      // Responsive scroll wrapper
      const scrollWrapper = document.createElement('div');
      scrollWrapper.className = 'pdf-scroll-wrapper';

      const container = document.createElement('div');
      container.className = 'page-container';
      container.style.width  = viewport.width  + 'px';
      container.style.height = viewport.height + 'px';

      const canvas  = document.createElement('canvas');
      canvas.width  = viewport.width;
      canvas.height = viewport.height;
      container.appendChild(canvas);

      await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;

      // Place input overlays
      FIELDS.forEach(f => {
        const el = f.multiline
          ? document.createElement('textarea')
          : document.createElement('input');

        el.id          = f.id;
        el.className   = 'field-overlay';
        el.placeholder = f.ph || '';
        if (!f.multiline) el.type = 'text';

        el.style.left   = f.x + '%';
        el.style.top    = f.y + '%';
        el.style.width  = f.w + '%';
        el.style.height = f.h + '%';
        el.style.fontSize = Math.max(8, viewport.height * 0.011) + 'px';

        if (f.multiline) el.style.overflow = 'hidden';

        container.appendChild(el);
      });

      scrollWrapper.appendChild(container);
      wrap.appendChild(scrollWrapper);
    }

    // Apply responsive scaling after render
    applyResponsiveScale();
    resetViewerPadding();

    loadSavedData();
  } catch(e) {
    status.textContent = '⚠ Error loading document: ' + e.message;
    console.error(e);
  }
}

// ══════════════════════════════════════════════════════
// LOAD SAVED DATA (restore last auto-draft from records)
// ══════════════════════════════════════════════════════
function loadSavedData() {
  // Try to restore last loaded record (if any) or just leave blank
  // No auto-restore to avoid overwriting intentional resets
  document.getElementById('status').textContent = '';
}

function applyResponsiveScale() {
  const containers = document.querySelectorAll('.page-container');
  if (!containers.length) return;

  const firstContainer = containers[0];
  const naturalWidth = parseInt(firstContainer.style.width, 10);
  if (!naturalWidth) return;

  // Available viewport width minus scrollbar + some padding
  const availableWidth = Math.min(window.innerWidth, document.documentElement.clientWidth) - 16;

  let scale = 1;
  if (availableWidth < naturalWidth) {
    scale = availableWidth / naturalWidth;
  }

  containers.forEach(c => {
    if (scale < 1) {
      const naturalW = parseInt(c.style.width, 10);
      const naturalH = parseInt(c.style.height, 10);
      c.style.transform = `scale(${scale})`;
      c.style.transformOrigin = 'top center';
      // Collapse the layout space to scaled size so no gap
      c.parentElement.style.height = Math.round(naturalH * scale) + 'px';
      c.parentElement.style.display = 'flex';
      c.parentElement.style.justifyContent = 'center';
      c.parentElement.style.alignItems = 'flex-start';
      c.parentElement.style.overflow = 'visible';
    } else {
      c.style.transform = '';
      c.style.transformOrigin = '';
      c.parentElement.style.height = '';
      c.parentElement.style.overflow = '';
    }
  });
}

// ══════════════════════════════════════════════════════
// STORAGE KEYS
// ══════════════════════════════════════════════════════
const RECORDS_KEY = 'vestas_pressure_records';
const HISTORY_KEY = 'vestas_pressure_history';

let currentRecordId = null;

// ══════════════════════════════════════════════════════
// COLLECT / POPULATE FIELD DATA
// ══════════════════════════════════════════════════════
function collectData() {
  const data = {};
  document.querySelectorAll('.field-overlay').forEach(el => {
    if (el.value) data[el.id] = el.value;
  });
  return data;
}

function populateData(data) {
  document.querySelectorAll('.field-overlay').forEach(el => {
    el.value = data[el.id] || '';
  });
}

// ══════════════════════════════════════════════════════
// RECORDS PERSISTENCE
// ══════════════════════════════════════════════════════
function getRecords() {
  try { return JSON.parse(localStorage.getItem(RECORDS_KEY)) || {}; } catch { return {}; }
}
function setRecords(r) { localStorage.setItem(RECORDS_KEY, JSON.stringify(r)); }

function getHistory() {
  try { return JSON.parse(localStorage.getItem(HISTORY_KEY)) || []; } catch { return []; }
}
function addHistory(action, id) {
  const h = getHistory();
  h.unshift({ ts: new Date().toISOString(), action, id });
  localStorage.setItem(HISTORY_KEY, JSON.stringify(h));
}

// ══════════════════════════════════════════════════════
// SAVE
// Saves using dc_no placeholder value as the key
// ══════════════════════════════════════════════════════
function saveRecord() {
  const data = collectData();
  // Use dc_no field value as the record key
  const dcEl = document.getElementById('dc_no');
  const dcVal = (dcEl ? dcEl.value.trim() : '') || (dcEl ? (dcEl.placeholder || '') : '');
  const id = dcVal || ('REC-' + Date.now());

  const records = getRecords();
  if (records[id]) {
    toast('Record already exists. Use Update to modify.', 'err');
    return;
  }
  records[id] = { id, savedAt: new Date().toISOString(), data };
  setRecords(records);
  currentRecordId = id;
  addHistory('SAVED', id);
  const lbl = document.getElementById('saved-label');
  lbl.textContent = `✔ Saved: ${id}`;
  lbl.style.display = 'inline';
  toast(`Saved as "${id}"`, 'ok');
}

// ══════════════════════════════════════════════════════
// UPDATE
// ══════════════════════════════════════════════════════
function updateRecord() {
  const data = collectData();
  const dcEl = document.getElementById('dc_no');
  const dcVal = (dcEl ? dcEl.value.trim() : '') || '';
  const id = currentRecordId || dcVal || ('REC-' + Date.now());

  const records = getRecords();
  const isNew = !records[id];
  records[id] = {
    id,
    savedAt: records[id]?.savedAt || new Date().toISOString(),
    updatedAt: new Date().toISOString(),
    data
  };
  setRecords(records);
  currentRecordId = id;
  addHistory(isNew ? 'SAVED' : 'UPDATED', id);
  const lbl = document.getElementById('saved-label');
  lbl.textContent = `✔ Updated: ${id}`;
  lbl.style.display = 'inline';
  toast(`Record "${id}" ${isNew ? 'saved' : 'updated'}`, 'ok');
}

// ══════════════════════════════════════════════════════
// RESET / CLEAR
// ══════════════════════════════════════════════════════
function resetForm() {
  if (!confirm('Clear all fields? Unsaved data will be lost.')) return;
  document.querySelectorAll('.field-overlay').forEach(el => el.value = '');
  currentRecordId = null;
  const lbl = document.getElementById('saved-label');
  lbl.textContent = '';
  lbl.style.display = 'none';
  document.getElementById('status').textContent = '';
  toast('Form cleared', 'info');
}

// ══════════════════════════════════════════════════════
// SEARCH by DC No
// ══════════════════════════════════════════════════════
function toggleSearch() {
  const bar = document.getElementById('search-bar');
  bar.classList.toggle('open');
  if (bar.classList.contains('open')) {
    document.getElementById('search-input').value = '';
    document.getElementById('search-results-list').innerHTML = '';
    document.getElementById('search-results-list').classList.remove('open');
    document.getElementById('search-input').focus();
    // Adjust viewer-wrap top padding
    const toolbarH = document.getElementById('toolbar').offsetHeight;
    const searchH  = bar.offsetHeight || 52;
    document.getElementById('viewer-wrap').style.paddingTop = (toolbarH + searchH + 10) + 'px';
  } else {
    resetViewerPadding();
  }
}

function doSearch(query) {
  const list = document.getElementById('search-results-list');
  if (!query.trim()) { list.innerHTML = ''; list.classList.remove('open'); return; }
  const records = getRecords();
  const q = query.toLowerCase();
  const matches = Object.values(records).filter(r => {
    const dcField = r.data && r.data['dc_no'];
    return r.id.toLowerCase().includes(q) || (dcField && dcField.toLowerCase().includes(q));
  });
  if (!matches.length) {
    list.innerHTML = '<div class="search-result-item" style="color:#888;cursor:default;">No records found</div>';
    list.classList.add('open');
    return;
  }
  list.innerHTML = matches.map(r => `
    <div class="search-result-item">
      <div>
        <div class="search-result-id">${r.id}</div>
        <div class="search-result-meta">Saved: ${fmtDate(r.savedAt)}</div>
      </div>
      <button class="search-result-load" onclick="loadRecord('${r.id}'); toggleSearch();">Load</button>
    </div>
  `).join('');
  list.classList.add('open');
}

// ══════════════════════════════════════════════════════
// MODALS
// ══════════════════════════════════════════════════════
function openModal(type) {
  const overlay = document.getElementById('modal-overlay');
  const title   = document.getElementById('modal-title');
  const body    = document.getElementById('modal-body');
  overlay.classList.add('open');

  if (type === 'records') {
    title.textContent = '📂 Saved Records';
    const records = getRecords();
    const keys = Object.keys(records);
    if (!keys.length) {
      body.innerHTML = '<div class="no-records">No saved records yet. Fill the form and click Save.</div>';
    } else {
      body.innerHTML = keys.map(k => {
        const r = records[k];
        return `<div class="record-item">
          <div class="record-info">
            <div class="record-id">${r.id}</div>
            <div class="record-meta">Saved: ${fmtDate(r.savedAt)}${r.updatedAt ? ' · Updated: ' + fmtDate(r.updatedAt) : ''}</div>
          </div>
          <div class="record-actions">
            <button class="rec-btn rec-load" onclick="loadRecord('${k}')">Load</button>
            <button class="rec-btn rec-del"  onclick="deleteRecord('${k}')">Delete</button>
          </div>
        </div>`;
      }).join('');
    }
  } else {
    title.textContent = '📜 Edit History';
    const hist = getHistory();
    if (!hist.length) {
      body.innerHTML = '<div class="no-records">No history yet.</div>';
    } else {
      body.innerHTML = hist.map(h =>
        `<div class="history-entry">
          <div class="h-time">${fmtDate(h.ts)}</div>
          <div class="h-action">${h.action} — <strong>${h.id}</strong></div>
        </div>`
      ).join('');
    }
  }
}

function loadRecord(id) {
  const records = getRecords();
  if (!records[id]) return;
  populateData(records[id].data);
  currentRecordId = id;
  const lbl = document.getElementById('saved-label');
  lbl.textContent = `📂 Loaded: ${id}`;
  lbl.style.display = 'inline';
  closeModal();
  addHistory('LOADED', id);
  toast(`Record "${id}" loaded`, 'ok');
}

function deleteRecord(id) {
  if (!confirm(`Delete record "${id}"?`)) return;
  const records = getRecords();
  delete records[id];
  setRecords(records);
  addHistory('DELETED', id);
  if (currentRecordId === id) {
    currentRecordId = null;
    const lbl = document.getElementById('saved-label');
    lbl.textContent = '';
    lbl.style.display = 'none';
  }
  openModal('records');
  toast(`Deleted "${id}"`, 'info');
}

function closeModal() { document.getElementById('modal-overlay').classList.remove('open'); }
function closeModalOutside(e) { if (e.target === document.getElementById('modal-overlay')) closeModal(); }

// ══════════════════════════════════════════════════════
// DOWNLOAD PDF (captures the PDF canvas + overlays)
// Uses dc_no value for filename
// ══════════════════════════════════════════════════════
async function downloadPDF() {
  toast('Generating PDF…', 'info');

  // Snapshot overlay values before capture
  const fields = [];
  document.querySelectorAll('.field-overlay').forEach(el => {
    fields.push({ el, bg: el.style.background, outline: el.style.outline, border: el.style.border });
    el.style.background = 'transparent';
    el.style.outline = 'none';
    el.style.border = 'none';
  });

  try {
    const { jsPDF } = window.jspdf;
    const pageContainers = document.querySelectorAll('.page-container');
    if (!pageContainers.length) { toast('Nothing to export yet', 'err'); return; }

    const pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
    const pdfW = pdf.internal.pageSize.getWidth();
    const pdfH = pdf.internal.pageSize.getHeight();

    for (let i = 0; i < pageContainers.length; i++) {
      const c = pageContainers[i];
      // Temporarily remove transform for capture
      const origTransform = c.style.transform;
      c.style.transform = 'none';
      const origOrigin   = c.style.transformOrigin;
      c.style.transformOrigin = '';

      const canvas = await html2canvas(c, {
        scale: 2,
        useCORS: true,
        backgroundColor: '#ffffff',
        logging: false,
        width: parseInt(c.style.width),
        height: parseInt(c.style.height),
        ignoreElements: (el) => el.id === 'toolbar' || el.id === 'search-bar'
      });

      c.style.transform = origTransform;
      c.style.transformOrigin = origOrigin;

      const imgData = canvas.toDataURL('image/png');

      // Always fit the entire page-container to exactly one A4 page
      if (i > 0) pdf.addPage();
      pdf.addImage(imgData, 'PNG', 0, 0, pdfW, pdfH);
    }

    // Filename from dc_no
    const dcEl    = document.getElementById('dc_no');
    const dcVal   = dcEl ? dcEl.value.trim() : '';
    const filename = dcVal ? `${dcVal}.pdf` : `VESTAS-CAL-${Date.now()}.pdf`;
    pdf.save(filename);
    addHistory('PDF DOWNLOADED', dcVal || filename);
    toast(`Downloaded: ${filename}`, 'ok');
  } catch(e) {
    console.error(e);
    toast('PDF generation failed. Try Print instead.', 'err');
  } finally {
    fields.forEach(({ el, bg, outline, border }) => {
      el.style.background = bg;
      el.style.outline = outline;
      el.style.border = border;
    });
  }
}

// ══════════════════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════════════════
function toast(msg, type = 'info') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `show ${type}`;
  clearTimeout(t._timer);
  t._timer = setTimeout(() => { t.className = ''; }, 3000);
}

// ══════════════════════════════════════════════════════
// DATE FORMATTER
// ══════════════════════════════════════════════════════
function fmtDate(iso) {
  try {
    return new Date(iso).toLocaleString('en-IN', {
      day: '2-digit', month: 'short', year: 'numeric',
      hour: '2-digit', minute: '2-digit'
    });
  } catch { return iso; }
}

