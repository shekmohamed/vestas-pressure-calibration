function toggleMenu() {
  const actions = document.getElementById('toolbar-actions');
  actions.classList.toggle('open');
}
function closeMenu() {
  document.getElementById('toolbar-actions').classList.remove('open');
}
// Close menu when clicking outside
document.addEventListener('click', function(e) {
  const toggle = document.getElementById('menu-toggle');
  const actions = document.getElementById('toolbar-actions');
  if (actions.classList.contains('open') && !toggle.contains(e.target) && !actions.contains(e.target)) {
    actions.classList.remove('open');
  }
});

// ══════════════════════════════════════════════════════
// TOOLBAR HEIGHT HELPER
// ══════════════════════════════════════════════════════
function resetViewerPadding() {
  const toolbarH = document.getElementById('toolbar').offsetHeight;
  document.getElementById('viewer-wrap').style.paddingTop = (toolbarH + 10) + 'px';
  // Keep search bar top in sync
  const searchBar = document.getElementById('search-bar');
  if (searchBar) searchBar.style.top = toolbarH + 'px';
}
window.addEventListener('resize', () => {
  resetViewerPadding();
  applyResponsiveScale();
});

init();
