    text-size-adjust: 100%;
  }

  body {
    font-family: Arial, sans-serif;
    background: #525659;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── Toolbar ── */
  #toolbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    background: #323639;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.4);
    min-height: 50px;
  }

  #toolbar h1 {
    color: #fff;
    font-size: clamp(11px, 2.5vw, 14px);
    font-weight: 600;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Hamburger toggle — visible only on small screens */
  #menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 6px;
    flex-shrink: 0;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }
  #menu-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
    margin: 5px 0;
    border-radius: 2px;
    transition: all 0.2s;
  }

  /* Dropdown action panel */
  .toolbar-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    flex-wrap: nowrap;
  }

  .btn {
    padding: 6px 12px;
    border: none;
    border-radius: 4px;
    font-size: clamp(11px, 2vw, 13px);
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }

  .btn-print {
    background: #0066cc;
    color: #fff;
  }
  .btn-print:hover, .btn-print:active { background: #0052a3; }

  .btn-clear {
    background: #555;
    color: #ddd;
  }
  .btn-clear:hover, .btn-clear:active { background: #444; }

  .btn-save {
    background: #2a7a2a;
    color: #fff;
  }
  .btn-save:hover, .btn-save:active { background: #1e5e1e; }

  .btn-update { background: #fd7e14; color: #fff; }
  .btn-update:hover, .btn-update:active { background: #e06b00; }

  .btn-download-pdf { background: #dc3545; color: #fff; }
  .btn-download-pdf:hover, .btn-download-pdf:active { background: #b52a37; }

  .btn-history { background: #17a2b8; color: #fff; }
  .btn-history:hover, .btn-history:active { background: #117a8b; }

  .btn-records { background: #0d6efd; color: #fff; }
  .btn-records:hover, .btn-records:active { background: #0a58ca; }

  #saved-label {
    color: #aed6f1;
    font-size: 11px;
    font-style: italic;
    flex-shrink: 0;
    white-space: nowrap;
    display: none;
  }

  /* ── Search bar ── */
  #search-bar {
    display: none;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: #1a2a3a;
    flex-wrap: wrap;
  }
  #search-bar.open { display: flex; }
  #search-input {
    flex: 1;
    min-width: 200px;
    padding: 5px 10px;
    border-radius: 4px;
    border: none;
    font-size: 12px;
    outline: none;
  }
  #search-results-list {
    width: 100%;
    max-height: 240px;
    overflow-y: auto;
    background: #fff;
    border-radius: 4px;
    display: none;
  }
  #search-results-list.open { display: block; }
  .search-result-item {
    padding: 8px 12px;
    border-bottom: 1px solid #eee;
    font-size: 12px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }
  .search-result-item:hover { background: #f0f6ff; }
  .search-result-id { font-weight: 700; color: #1a3a5c; }
  .search-result-meta { color: #666; font-size: 11px; }
  .search-result-load {
    padding: 3px 10px;
    background: #0d6efd;
    color: #fff;
    border: none;
    border-radius: 3px;
    font-size: 11px;
    cursor: pointer;
    flex-shrink: 0;
  }

  /* ── Modal ── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.55);
    z-index: 9000;
    align-items: flex-start;
    justify-content: center;
    padding: 40px 16px;
  }
  .modal-overlay.open { display: flex; }

  .modal {
    background: #fff;
    border-radius: 6px;
    width: 700px;
    max-width: 100%;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 40px rgba(0,0,0,.4);
  }

  .modal-header {
    padding: 12px 16px;
    background: #1a3a5c;
    color: #fff;
    font-weight: 700;
    font-size: 13px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-radius: 6px 6px 0 0;
    flex-shrink: 0;
  }

  .modal-close {
    background: none;
    border: none;
    color: #fff;
    font-size: 22px;
    cursor: pointer;
    line-height: 1;
    padding: 0;
  }

  .modal-body {
    overflow-y: auto;
    padding: 14px;
    flex: 1;
  }

  .record-item {
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 10px 12px;
    margin-bottom: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }
  .record-item:hover { background: #f8f8f8; }
  .record-info { flex: 1; font-size: 12px; }
  .record-id   { font-weight: 700; font-size: 13px; color: #1a3a5c; }
  .record-meta { color: #666; font-size: 11px; margin-top: 2px; }
  .record-actions { display: flex; gap: 6px; flex-shrink: 0; }

  .rec-btn {
    padding: 4px 11px;
    border: none;
    border-radius: 3px;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    touch-action: manipulation;
  }
  .rec-load { background: #0d6efd; color: #fff; }
  .rec-del  { background: #dc3545; color: #fff; }
  .no-records { text-align: center; color: #888; padding: 30px 0; font-size: 13px; }

  .history-entry {
    border-left: 3px solid #0d6efd;
    padding: 5px 10px;
    margin-bottom: 6px;
    background: #f4f8ff;
    font-size: 11px;
  }
  .history-entry .h-time { font-weight: 700; color: #1a3a5c; }
  .history-entry .h-action { color: #333; margin-top: 2px; }

  /* ── Toast ── */
  #toast {
    position: fixed;
    bottom: 24px;
    right: 16px;
    background: #1a3a5c;
    color: #fff;
    padding: 10px 18px;
    border-radius: 5px;
    font-size: 12.5px;
    font-weight: 600;
    z-index: 9999;
    opacity: 0;
    transform: translateY(10px);
    transition: all .3s;
    pointer-events: none;
    max-width: calc(100vw - 32px);
  }
  #toast.show { opacity: 1; transform: translateY(0); }
  #toast.ok   { background: #1a7a3c; }
  #toast.err  { background: #a50000; }
  #toast.info { background: #1a3a5c; }

  #status {
    color: #aaa;
    font-size: clamp(10px, 1.8vw, 12px);
    flex-shrink: 0;
    white-space: nowrap;
  }
  #viewer-wrap {
    padding: 60px 0 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  /* ── Responsive scroll container ── */
  .pdf-scroll-wrapper {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    display: flex;
    justify-content: center;
    padding: 0 8px;
  }

  .page-container {
    position: relative;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    background: #fff;
    display: block;
    flex-shrink: 0;
    transform-origin: top left;
  }

  .page-container canvas {
    display: block;
    max-width: none;
  }

  /* ── Overlay fields ── */
  .field-overlay {
    position: absolute;
    background: rgba(255, 255, 180, 0.55);
    border: 1px solid rgba(180,140,0,0.4);
    border-radius: 2px;
    font-family: Arial, sans-serif;
    font-size: 11px;
    color: #111;
    outline: none;
    padding: 1px 3px;
    resize: none;
    line-height: 1.3;
    transition: background 0.1s, border 0.1s;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .field-overlay:focus {
    background: rgba(255, 255, 200, 0.9);
    border-color: #0066cc;
    box-shadow: 0 0 0 2px rgba(0,102,204,0.25);
    z-index: 10;
  }

  .field-overlay::placeholder {
    color: #aaa;
    font-size: 9px;
  }

  /* ── Mobile: hamburger menu ── */
  @media (max-width: 768px) {
    #menu-toggle { display: block; }

    .toolbar-actions {
      display: none;
      position: fixed;
      top: 50px;
      left: 0; right: 0;
      background: #2b2e31;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 8px 12px 12px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.5);
      z-index: 999;
      flex-wrap: nowrap;
    }

    .toolbar-actions.open {
      display: flex;
    }

    .toolbar-actions .btn {
      width: 100%;
      justify-content: flex-start;
      padding: 10px 14px;
      font-size: 13px;
      border-radius: 4px;
      margin-bottom: 4px;
      min-height: 40px;
    }

    #saved-label {
      padding: 6px 14px;
      font-size: 12px;
    }

    #status {
      display: none;
    }

    #toolbar h1 {
      font-size: clamp(11px, 3.5vw, 13px);
    }
  }

  @media (max-width: 480px) {
    #toolbar {
      padding: 6px 10px;
    }
    .toolbar-actions {
      top: 46px;
    }
  }

  /* ── Desktop / Laptop ── */
  @media (min-width: 769px) {
    #toolbar {
      padding: 10px 20px;
      gap: 12px;
    }
    #toolbar h1 {
      font-size: 14px;
    }
    .btn {
      padding: 7px 14px;
      font-size: 13px;
    }
    #viewer-wrap {
      padding-top: 70px;
    }
  }

  /* ── Print ── */
  @media print {
    @page {
      size: A4;
      margin: 0;
    }

    body { background: white; }
    #toolbar { display: none !important; }
    #search-bar { display: none !important; }
    .modal-overlay { display: none !important; }
    #toast { display: none !important; }
    #viewer-wrap {
      padding: 0 !important;
      margin: 0 !important;
      gap: 0 !important;
      overflow: visible;
      display: block !important;
    }
    .pdf-scroll-wrapper {
      overflow: visible;
      padding: 0 !important;
      margin: 0 !important;
      height: auto !important;
      display: block !important;
    }

    .page-container {
      box-shadow: none;
      break-inside: avoid;
      page-break-inside: avoid;
      transform: none !important;
      margin: 0 !important;
      padding: 0 !important;
      width: 210mm !important;
      height: 297mm !important;
      overflow: hidden !important;
    }

    .page-container canvas {
      width: 210mm !important;
      height: 297mm !important;
      display: block !important;
    }

    /* Page break BETWEEN pages, but NOT after the last one */
    .page-container:not(:last-child) {
      break-after: page;
      page-break-after: always;
    }

    .page-container:last-child {
      break-after: avoid;
      page-break-after: avoid;
    }

    .field-overlay {
      background: transparent !important;
      border: none !important;
      box-shadow: none !important;
      color: #000 !important;
    }
  }
</style>
</head>
